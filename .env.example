# Server Configurations
PORT=5000
NODE_ENV=development

# Database Configurations
MONGO_URI=mongodb://localhost:27017/prakritastro

# Authentication Secret
JWT_SECRET=your_jwt_signing_secret_here_make_it_long_and_complex

# Admin Seed Configurations (automatically seeded on seed script execution)
ADMIN_NAME=Ramendra & Rekha
ADMIN_EMAIL=admin@prakritastro.com
ADMIN_PASSWORD=change_this_to_a_secure_password_on_production

# Razorpay API Credentials (required)
RAZORPAY_KEY_ID=rzp_test_your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_secret_key
RAZORPAY_WEBHOOK_SECRET=your_optional_webhook_secret

# PhonePe API Credentials (future placeholder)
PHONEPE_MERCHANT_ID=your_phonepe_merchant_id
PHONEPE_SALT_KEY=your_phonepe_salt_key
PHONEPE_SALT_INDEX=1
PHONEPE_BASE_URL=https://api-preprod.phonepe.com/apis/pg-sandbox

# Cashfree API Credentials (optional fallback structure ready)
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret_key

# Active Gateway Configuration
ACTIVE_PAYMENT_GATEWAY=razorpay
